# ─── App ───────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
# UPLOAD_DIR=/app/uploads

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://devknowledge:devknowledge@localhost:5432/devknowledge
POSTGRES_PASSWORD=devknowledge

# ─── Auth ──────────────────────────────────────────────────────────────────────
API_KEY=dev-secret-key-change-in-prod

# ─── API Keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...

# ─── RAG — Chunking ────────────────────────────────────────────────────────────
# CHUNKING_STRATEGY: 'sentence' | 'recursive'
CHUNKING_STRATEGY=sentence
CHUNK_SIZE_TOKENS=128
CHUNK_OVERLAP_TOKENS=32

# ─── RAG — Reranking ───────────────────────────────────────────────────────────
# RERANK_ENABLED: true | false (default: true)
RERANK_MODEL=rerank-2.5
# RERANK_CANDIDATE_MULTIPLIER=3

# ─── RAG — Retrieval ───────────────────────────────────────────────────────────
RETRIEVAL_LIMIT=5
RETRIEVAL_MIN_SCORE=0.35

# ─── LLM ───────────────────────────────────────────────────────────────────────
LLM_MODEL=claude-haiku-4-5-20251001
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.1
